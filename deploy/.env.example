# Copy to deploy/.env and fill in. docker compose reads it automatically.

# --- PostgreSQL ---
POSTGRES_USER=gateway
POSTGRES_PASSWORD=change-me
POSTGRES_DB=gateway

# --- Gateway operational defaults (seed the DB on first run; edit live in the
#     panel's Server Settings afterwards) ---
GATEWAY=gateway.someserver.net
DEVICE_WEBHOOK_URL=https://db.example.net/universal/gps/json/

# --- Admin panel access ---
# Shared internal token the panel uses to talk to the gateway. This is all the
# panel needs — no pre-minted API key. The same value is given to the gateway
# (INTERNAL_API_TOKEN) and the admin (GATEWAY_API_TOKEN). Generate:
#   openssl rand -hex 32
ADMIN_API_TOKEN=replace-with-openssl-rand-hex-32

# Secret used to sign admin session cookies (>=16 chars). Generate:
#   openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string
SESSION_TTL_HOURS=12
