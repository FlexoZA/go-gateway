# Reference of every gateway environment variable. For the bundled docker-compose
# stack, the practical template is deploy/.env.example (copy it to deploy/.env,
# which compose reads automatically). This file documents all gateway vars.

# Human identifier for this gateway instance (appears in the "gateway" field).
GATEWAY=dfm-gw1.cwe.cloud

# Device TCP listener.
LISTEN_HOST=0.0.0.0
LISTEN_PORT=33000

# Management/control HTTP API (API-key protected via Authorization: Bearer). 0 disables.
HTTP_PORT=8080

# Shared internal token the admin panel uses to authenticate to this API (accepted
# alongside DB-minted API keys; lets the panel work before any key exists, which
# enables first-run setup). Must match the admin's GATEWAY_API_TOKEN. In compose
# both come from ADMIN_API_TOKEN. Generate: openssl rand -hex 32
INTERNAL_API_TOKEN=

# Telemetry sink: the universal-JSON endpoint that stores all GPS/event data.
DEVICE_WEBHOOK_URL=http://gateway.acmtrack.net:8080/universal/gps/json/

# PostgreSQL — the gateway's OWN database: device-verification registry (and
# future server-settings tables). GPS/event telemetry is NOT stored here.
DATABASE_URL=postgres://gateway:gateway@postgres:5432/gateway?sslmode=disable
# Credentials for the bundled postgres service (used to build DATABASE_URL above).
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway
POSTGRES_DB=gateway

# Device authorization: allow_all | postgres (defaults to postgres when DATABASE_URL set).
DEVICE_AUTH_MODE=postgres
# true = quarantine + reject unknown serials (require approval, default); false =
# auto-provision + admit. Seeds the device_reject_unknown setting on first run.
DEVICE_REJECT_UNKNOWN=true

# Mapping edits apply instantly via Postgres NOTIFY; this is just a safety-net
# reload interval in case a notification is missed (seconds; 0 disables the net).
MAPPING_REFRESH_SECONDS=60

# Message timestamp offset in hours (production uses 0 = UTC).
WEBHOOK_TIMEZONE_OFFSET=0

# Verbose logging: 1 / true / * for everything, or a namespace like tcp/howen.
DEBUG=
