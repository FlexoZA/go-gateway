# Admin panel configuration (server-side only — never exposed to the browser).

# Where the gateway HTTP API lives. In docker-compose this is the service name.
GATEWAY_URL=http://localhost:8080

# Shared internal service token the panel uses to authenticate to the gateway
# (must match the gateway's INTERNAL_API_TOKEN). This is all the panel needs — no
# pre-minted API key — and it works before any key exists, enabling first-run
# setup. Generate: openssl rand -hex 32
GATEWAY_API_TOKEN=replace-with-openssl-rand-hex-32

# Legacy fallback: a DB-minted API key (dgw_..., from cmd/apikey or the API Keys
# page) is still accepted if GATEWAY_API_TOKEN is not set.
# GATEWAY_API_KEY=dgw_...

# Secret used to sign admin session cookies (>=16 chars). Generate a random one:
#   openssl rand -base64 32
SESSION_SECRET=change_me_to_a_long_random_string

# Optional: session lifetime in hours (default 12).
SESSION_TTL_HOURS=12
