// Package __UNIT__ implements the __UNIT__ GPS tracker as a gateway plugin.
//
// This is a scaffold generated by scripts/new-gateway.sh. It frames the device
// stream as newline-delimited text and parses a placeholder CSV line. Replace
// ReadFrame and parseLine with your device's real wire format, then forward a
// normalized payload via conn.Emit — the universal webhook handles the rest.
package __UNIT__

import (
	"bufio"
	"context"
	"strconv"
	"strings"

	"github.com/dfm/device-gateway/internal/core/device"
	"github.com/dfm/device-gateway/internal/core/gateway"
)

const unitName = "__UNIT__"

// Protocol is the __UNIT__ unit-type plugin.
type Protocol struct{}

// New returns a __UNIT__ protocol plugin.
func New() *Protocol { return &Protocol{} }

func (*Protocol) Name() string { return unitName }

// Capabilities: GPS-only trackers declare nothing optional, so no dead
// media/control/config code is wired in. To add a feature later, set the relevant
// flag here AND have the session implement the matching interface:
//   HasVideo    → gateway.VideoController
//   HasCommands → gateway.Commander
//   HasConfig   → gateway.ConfigController
//   HasStatus   → gateway.StatusReporter
//
// Two further optional seams are detected by the app runner via type assertion on
// *Protocol (implement only if needed; a GPS-only unit implements neither):
//   gateway.MappingProvider     — editable code→event mappings + per-model workflows
//   gateway.MediaServerProvider — a device-side media (video) accept loop
func (*Protocol) Capabilities() gateway.Capabilities {
	return gateway.Capabilities{} // all false
}

// ReadFrame decodes one frame. TODO: replace newline framing with the device's
// real framing (binary header, length prefix, etc.).
func (*Protocol) ReadFrame(r *bufio.Reader) (gateway.Frame, error) {
	line, err := r.ReadBytes('\n')
	if err != nil {
		return gateway.Frame{}, err
	}
	return gateway.Frame{Type: 0, Payload: line}, nil
}

func (*Protocol) NewSession(c *gateway.Conn) gateway.Session {
	return &session{conn: c}
}

type session struct {
	conn   *gateway.Conn
	serial string
}

// OnFrame parses a frame and forwards a normalized GPS payload.
func (s *session) OnFrame(ctx context.Context, f gateway.Frame) error {
	payload, serial, ok := parseLine(string(f.Payload))
	if !ok {
		s.conn.Deps.Log.Debug(map[string]any{"event": "unparsed_line", "unit": unitName})
		return nil
	}
	s.serial = device.NormalizeSerial(serial)

	// Optional: gate unknown devices using the configured authenticator.
	res, err := s.conn.Deps.Auth.Authorize(ctx, device.RegisterInfo{Serial: s.serial, Protocol: unitName, RemoteIP: s.conn.RemoteIP()})
	if err != nil || !res.Known {
		return nil
	}

	// model is the second positional field of the universal device record; set
	// it to your hardware model.
	s.conn.Emit(s.serial, unitName, unitName, "gps", payload)
	return nil
}

func (s *session) OnClose(ctx context.Context) {}

// parseLine is a placeholder parser for "serial,lat,lon,speed,utc". Replace it
// with your device's real decoding. Returns (normalizedPayload, serial, ok).
func parseLine(line string) (map[string]any, string, bool) {
	parts := strings.Split(strings.TrimSpace(line), ",")
	if len(parts) < 5 {
		return nil, "", false
	}
	serial := parts[0]
	lat, err1 := strconv.ParseFloat(parts[1], 64)
	lon, err2 := strconv.ParseFloat(parts[2], 64)
	speed, err3 := strconv.ParseFloat(parts[3], 64)
	utc, err4 := strconv.ParseInt(parts[4], 10, 64)
	if err1 != nil || err2 != nil || err3 != nil || err4 != nil {
		return nil, "", false
	}
	// These keys are read by the universal-message builder in
	// internal/core/message/message.go (see Builder.Build). The full set it
	// understands, all optional:
	//   position : latitude, longitude, positioning, altitude, speed,
	//              heading|bearing, satellites, hdop|accuracy, vdop, pdop, tdop
	//   time     : utc (epoch seconds) or timestamp
	//   identity : imei, serial_no, firm_ver|firmware_version, type, model
	//   network  : signal_lvl|signal, signal_str, carrier, lac, data_mode
	//   sim      : msisdn, iccid, imsi
	//   trip     : odometer|mileage_km, trip_odo, gnss
	//   events   : event (a string or array of event codes) — emit final codes
	//              directly; the editable code→event remap (MappingProvider) is
	//              only needed if you want it tunable from the admin panel
	//   io       : inputs, outputs, aux_inputs, an_inputs, sensors, can_bus
	// The serial comes from the OnFrame arg, not this map.
	return map[string]any{
		"latitude":    lat,
		"longitude":   lon,
		"speed":       speed,
		"utc":         float64(utc),
		"positioning": float64(1),
	}, serial, true
}
