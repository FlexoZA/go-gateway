// Command __UNIT__ runs the __UNIT__ unit-type gateway server.
//
// One binary, one unit type. All the gateway wiring (config, Postgres registry,
// telemetry webhook, HTTP API, live settings, …) lives in internal/core/app; this
// main just selects the __UNIT__ protocol. Implement the wire format in
// internal/__UNIT__/protocol.go.
package main

import (
	"github.com/dfm/device-gateway/internal/core/app"
	"github.com/dfm/device-gateway/internal/__UNIT__"
)

func main() { app.Run(__UNIT__.New()) }
